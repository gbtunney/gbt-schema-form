{
    "name": "root",
    "targets": {
        "build:self": {
            "executor": "nx:run-commands",

            "outputs": [
                "{projectRoot}/src/**/*.js",
                "{projectRoot}/src/**/*.d.ts",
                "{projectRoot}/src/**/*.js.map",
                "{projectRoot}/src/**/*.d.ts.map"
            ],
            "options": {
                "command": "pnpm exec tsc --build"
            }
        }
    }
}
