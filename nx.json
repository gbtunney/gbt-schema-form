{
    "tasksRunnerOptions": {
        "default": {
            "runner": "nx/tasks-runners/default",
            "options": {
                "cacheableOperations": ["build", "build:ts", "test"] //"build:self",
            }
        }
    },
    "targetDefaults": {
        "build": {
            "dependsOn": ["build:ts", "^build"]
        },
        "test": {
            "dependsOn": ["build:ts", "^test"]
        },
        "docs:build": {
            "dependsOn": ["build", "test", "^docs:build"]
        }
    }
}
