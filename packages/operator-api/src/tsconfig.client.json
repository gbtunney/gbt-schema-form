{
    "extends": "@snailicide/build-config/tsconfig-base",
    "compilerOptions": {
        // "outDir": "./../types" /* Specify an output folder for all emitted files. */,
        "sourceMap": true,
        "declaration": true,
        //    "declarationDir": "./../types",
        "declarationMap": true,
        "lib": ["ESNext", "DOM"],
        "exactOptionalPropertyTypes": false,
        "skipLibCheck": true
    },
    "include:[": ["./**/*.ts", "./client.integration.ts"],
    "exclude": ["./scratch/*", "./index.ts", "./*.test.ts", "node_modules"]
}
