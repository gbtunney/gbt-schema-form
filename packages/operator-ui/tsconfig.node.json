{
    "extends": "@snailicide/build-config/tsconfig-base",
    "compilerOptions": {
        "rootDir": ".",
        "types": ["node"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "sourceMap": true,
        "esModuleInterop": true,
        "declaration": true,
        "declarationMap": true
    },
    "include": ["./*.ts", "./.storybook/*.ts", "./*.mts", "./*.cts"]
}
