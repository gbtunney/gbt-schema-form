# Root .env.example — copy relevant sections into each package's .env
#
# Environment strategy:
#
#   local dev  → .env file in each package (gitignored)
#   CI         → GitHub Actions secrets (Settings → Secrets → Actions)
#   staging    → environment variables set in your hosting platform
#   production → environment variables set in your hosting platform
#
# Never commit real values. .env is gitignored.
# Only .env.example is committed.

# ── operator-api-server ───────────────────────────────────────────────────────
# Copy to packages/operator-api-server/.env

OPENAI_API_KEY=sk-...       # required for proposals + Whisper
PORT=3001                   # optional, defaults to 3001

# ── operator-ui / operator-api-client ─────────────────────────────────────────
# Copy to packages/operator-ui/.env
# Vite bakes this in at build time via import.meta.env.VITE_API_URL

VITE_API_URL=http://localhost:3001      # local dev
# VITE_API_URL=https://api.staging.myapp.com   # staging
# VITE_API_URL=https://api.myapp.com           # production
